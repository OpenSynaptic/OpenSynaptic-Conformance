{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/OpenSynaptic/OpenSynaptic-Conformance/blob/main/schemas/vector-set.schema.json",
  "title": "OpenSynaptic Conformance Vector Set",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schemaVersion",
    "vectorSetId",
    "version",
    "title",
    "description",
    "category",
    "vectors"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "kind": {
      "const": "vector-set"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "vectorSetId": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": [
        "crc",
        "base62",
        "frame",
        "command",
        "dataset",
        "custom"
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "vectors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/vectorEntry"
      }
    }
  },
  "$defs": {
    "vectorEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "operation",
        "appliesTo",
        "input",
        "expected"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "operation": {
          "type": "string",
          "minLength": 1
        },
        "appliesTo": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        },
        "input": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": true
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        },
        "expected": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": true
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "note": {
          "type": "string"
        }
      }
    }
  }
}