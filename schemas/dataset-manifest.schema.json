{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/OpenSynaptic/OpenSynaptic-Conformance/blob/main/schemas/dataset-manifest.schema.json",
  "title": "OpenSynaptic Conformance Dataset Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schemaVersion",
    "datasetId",
    "version",
    "title",
    "description",
    "datasetClass",
    "source",
    "cases"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "kind": {
      "const": "dataset-manifest"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "datasetId": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "datasetClass": {
      "type": "string",
      "enum": [
        "canonical",
        "exhaustive",
        "generated",
        "aggregate"
      ]
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "appliesTo": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/caseEntry"
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "section": {
          "type": "string"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "caseEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "category"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "appliesTo": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        },
        "input": {
          "type": "object",
          "additionalProperties": true
        },
        "expected": {
          "type": "object",
          "additionalProperties": true
        },
        "note": {
          "type": "string"
        }
      }
    }
  }
}