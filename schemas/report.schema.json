{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/OpenSynaptic/OpenSynaptic-Conformance/blob/main/schemas/report.schema.json",
  "title": "OpenSynaptic Conformance Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schemaVersion",
    "reportId",
    "createdAt",
    "repositoryVersion",
    "profileId",
    "implementation",
    "summary",
    "results"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "kind": {
      "const": "conformance-report"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "reportId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "repositoryVersion": {
      "type": "string",
      "minLength": 1
    },
    "profileId": {
      "type": "string",
      "minLength": 1
    },
    "datasetVersion": {
      "type": [
        "string",
        "null"
      ]
    },
    "implementation": {
      "$ref": "#/$defs/implementation"
    },
    "environment": {
      "type": "object",
      "additionalProperties": true
    },
    "aggregateSummary": {
      "$ref": "#/$defs/aggregateSummary"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/resultEntry"
      }
    }
  },
  "$defs": {
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "adapter",
        "target"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string"
        },
        "adapter": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": "string"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "passed",
        "failed",
        "skipped",
        "status"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        },
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL",
            "PARTIAL",
            "ERROR"
          ]
        },
        "note": {
          "type": "string"
        }
      }
    },
    "aggregateSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "passed",
        "failed",
        "skipped"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        },
        "passRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "suiteCount": {
          "type": "integer",
          "minimum": 0
        },
        "source": {
          "type": "string"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "resultEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL",
            "SKIP",
            "ERROR"
          ]
        },
        "vectorSetId": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "durationMs": {
          "type": "number",
          "minimum": 0
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}