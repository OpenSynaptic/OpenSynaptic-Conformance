{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/OpenSynaptic/OpenSynaptic-Conformance/blob/main/schemas/adapter-capabilities.schema.json",
  "title": "OpenSynaptic Adapter Capabilities",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schemaVersion",
    "adapterId",
    "roles",
    "supportedProfiles",
    "commands"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "kind": {
      "const": "adapter-capabilities"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "adapterId": {
      "type": "string",
      "minLength": 1
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "producer",
          "consumer",
          "fusion",
          "security",
          "ecosystem"
        ]
      }
    },
    "supportedProfiles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "info",
          "capabilities",
          "run-profile",
          "run-cases"
        ]
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": true
    },
    "limits": {
      "type": "object",
      "additionalProperties": true
    },
    "note": {
      "type": "string"
    }
  }
}