{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/OpenSynaptic/OpenSynaptic-Conformance/blob/main/schemas/profile.schema.json",
  "title": "OpenSynaptic Conformance Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schemaVersion",
    "profileId",
    "version",
    "title",
    "level",
    "status",
    "description",
    "appliesTo",
    "requirements",
    "execution",
    "passCriteria",
    "skipPolicy",
    "report"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "kind": {
      "const": "conformance-profile"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "profileId": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "level": {
      "type": "string",
      "pattern": "^L[1-5]$"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "stable",
        "deprecated"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "appliesTo": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      }
    },
    "prerequisites": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      },
      "default": []
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/requirement"
      }
    },
    "execution": {
      "$ref": "#/$defs/execution"
    },
    "passCriteria": {
      "$ref": "#/$defs/passCriteria"
    },
    "skipPolicy": {
      "$ref": "#/$defs/skipPolicy"
    },
    "report": {
      "$ref": "#/$defs/reportRef"
    }
  },
  "$defs": {
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "title",
        "requiredCases"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "vector-set",
            "procedure",
            "dataset"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string"
        },
        "appliesTo": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        },
        "requiredCases": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "note": {
          "type": "string"
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "single-implementation",
            "cross-implementation",
            "mixed"
          ]
        },
        "requiredPairs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/executionPair"
          },
          "default": []
        },
        "note": {
          "type": "string"
        }
      }
    },
    "executionPair": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer",
        "consumer",
        "cases"
      ],
      "properties": {
        "producer": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "consumer": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "cases": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "note": {
          "type": "string"
        }
      }
    },
    "passCriteria": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy"
      ],
      "properties": {
        "policy": {
          "type": "string",
          "enum": [
            "all-required-must-pass",
            "threshold"
          ]
        },
        "minimumPassed": {
          "type": "integer",
          "minimum": 0
        },
        "minimumPassRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "note": {
          "type": "string"
        }
      }
    },
    "skipPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed"
      ],
      "properties": {
        "allowed": {
          "type": "boolean"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "reportRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaPath",
        "requiredSummaryFields"
      ],
      "properties": {
        "schemaPath": {
          "type": "string"
        },
        "requiredSummaryFields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}